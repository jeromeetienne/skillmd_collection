{
    "name": "resumejson_cli",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "dev": "npx tsx ./src/cli.ts",
        "dev:from_pdf": "npm run dev -- from_pdf -i ./data/samples/resume_webdev.resume.pdf -o ./outputs/resume_webdev.resume.json",
        "dev:to_pdf:optimized": "npm run dev -- to_pdf -i ./outputs/resume_webdev.optimized.resume.json -o ./outputs/resume_webdev.optimized.resume.pdf",
        "dev:to_markdown:optimized": "npm run dev -- to_markdown -i ./outputs/resume_webdev.optimized.resume.json -o ./outputs/resume_webdev.output.resume.md",
        "dev:from_markdown:optimized": "npm run dev -- from_markdown -i ./outputs/resume_webdev.output.resume.md -o ./outputs/resume_webdev.from_markdown.resume.json",
        "dev:ats_score": "npm run dev -- ats_score -i ./outputs/resume_webdev.resume.json -o ./outputs/resume_webdev.ats_score.json",
        "dev:ats_score:optimized": "npm run dev -- ats_score -i ./outputs/resume_webdev.optimized.resume.json -o ./outputs/resume_webdev.optimized.ats_score.json",
        "dev:ats_question": "npm run dev -- ats_question -i ./outputs/resume_webdev.resume.json -o ./outputs/resume_webdev.unanswered.ats_question.json",
        "dev:ats_answering": "npm run dev -- ats_answering -i ./outputs/resume_webdev.resume.json -q ./outputs/resume_webdev.unanswered.ats_question.json -o ./outputs/resume_webdev.answered.ats_question.json",
        "dev:ats_answered": "npm run dev -- ats_answered -i ./outputs/resume_webdev.resume.json -q ./outputs/resume_webdev.answered.ats_question.json -o ./outputs/resume_webdev.answered.resume.json",
        "dev:ats_review:answered": "npm run dev -- ats_review -i ./outputs/resume_webdev.answered.resume.json -o ./outputs/resume_webdev.answered.ats_review.json",
        "dev:ats_optimize:answered": "npm run dev -- ats_optimize -i ./outputs/resume_webdev.answered.resume.json -r ./outputs/resume_webdev.answered.ats_review.json -o ./outputs/resume_webdev.optimized.resume.json",
        "full_pipeline": "npm run dev:from_pdf && npm run dev:ats_score && npm run dev:ats_question && npm run dev:ats_answering && npm run dev:ats_answered && npm run dev:ats_review:answered && npm run dev:ats_optimize:answered && npm run dev:to_pdf:optimized && npm run dev:to_markdown:optimized && npm run dev:from_markdown:optimized",
        "clean:outputs": "rm -f ./outputs/*.json",
        "build": "tsc -p tsconfig.build.json",
        "typecheck": "tsc --noEmit -p tsconfig.build.json",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@ai-sdk/openai": "^3.0.53",
        "@jeromeetienne/openai-cache": "^1.0.13",
        "@keyv/sqlite": "^4.0.8",
        "ai": "^6.0.168",
        "commander": "^14.0.3",
        "mustache": "^4.2.0",
        "openai-cache": "^1.0.35",
        "pdf-to-img": "^6.0.0",
        "puppeteer": "^24.42.0",
        "typescript": "^6.0.3",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@types/mustache": "^4.2.6",
        "@types/node": "^25.6.0"
    }
}