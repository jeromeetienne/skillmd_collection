{
    "name": "resumejson_cli",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "dev": "npx tsx ./src/cli.ts",
        "dev:from_pdf": "npm run dev -- from_pdf -i ./data/samples/resume_webdev.resume.pdf -o ./outputs/resume_webdev.resume.json",
        "dev:ats_score": "npm run dev -- ats_score -i ./outputs/resume_webdev.resume.json -o ./outputs/resume_webdev.ats_score.json",
        "dev:ats_review": "npm run dev -- ats_review -i ./outputs/resume_webdev.resume.json -o ./outputs/resume_webdev.ats_review.json",
        "dev:ats_question": "npm run dev -- ats_question -i ./outputs/resume_webdev.resume.json -o ./outputs/resume_webdev.ats_question.json",
        "dev:ats_answering": "npm run dev -- ats_answering -i ./outputs/resume_webdev.resume.json -q ./outputs/resume_webdev.ats_question.json -o ./outputs/resume_webdev.ats_answering.json",
        "dev:ats_answered": "npm run dev -- ats_answered -i ./outputs/resume_webdev.resume.json -q ./outputs/resume_webdev.ats_question.json -o ./outputs/resume_webdev.answered.resume.json",
        "build": "tsc -p tsconfig.build.json",
        "typecheck": "tsc --noEmit -p tsconfig.build.json",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@ai-sdk/openai": "^3.0.53",
        "@jeromeetienne/openai-cache": "^1.0.13",
        "@keyv/sqlite": "^4.0.8",
        "ai": "^6.0.168",
        "commander": "^14.0.3",
        "openai-cache": "^1.0.35",
        "pdf-to-img": "^6.0.0",
        "puppeteer": "^24.42.0",
        "typescript": "^6.0.3",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@types/node": "^25.6.0"
    }
}