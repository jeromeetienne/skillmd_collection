{
    "name": "bsky_client",
    "version": "1.1.4",
    "description": "Command-line interface for Bluesky social media interactions",
    "main": "dist/src/cli.js",
    "bin": {
        "bsky_client": "./dist/src/cli.js"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "postbuild": "chmod +x ./dist/src/cli.js && cp -r skills dist/skills",
        "typecheck": "tsc --noEmit",
        "dev": "tsx ./src/cli.ts",
        "start": "node dist/src/cli.js",
        "build:watch": "tsc -p tsconfig.build.json --watch",
        "publish:all": "npm run build && npm version patch && npm publish --access public",
        "test": "node --import tsx --test ./test/*.test.ts"
    },
    "keywords": [
        "bluesky",
        "cli",
        "social-media"
    ],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "dependencies": {
        "@atproto/api": "^0.12.0",
        "chalk": "^5.3.0",
        "commander": "^14.0.3"
    },
    "devDependencies": {
        "@types/node": "^20.19.37",
        "tsx": "^4.7.0",
        "typescript": "^5.3.3"
    }
}