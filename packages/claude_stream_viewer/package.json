{
    "name": "claude_stream_viewer",
    "version": "1.0.15",
    "description": "Claude Stream Viewer - Pretty-prints Claude API stream-json events from stdin with colorized output.",
    "main": "dist/cli.js",
    "bin": {
        "claude_stream_viewer": "dist/cli.js"
    },
    "scripts": {
        "dev": "tsx ./src/cli.ts",
        "sample:basic": "cat ./data/claude_events/basic.claude_events.jsonl | npm run dev",
        "sample:video_generation": "cat ./data/claude_events/video_generation.claude_events.jsonl | npm run dev",
        "build": "tsc -p tsconfig.build.json",
        "postbuild": "chmod +x ./dist/cli.js",
        "version:bump": "npm version patch --no-git-tag-version && git commit -a -m \"feat: bump version in claude_stream_viewer package.json\"",
        "publish:all": "npm run version:bump && npm run build && npm publish --access public",
        "typecheck": "tsc --noEmit",
        "demo_vhs:gif": "cd demo_vhs && vhs demo.tape",
        "demo_vhs:gif:compress": "cd demo_vhs && gifsicle --lossy=80 --colors 64  -O3 claude_stream_viewer.gif -o claude_stream_viewer.compressed.gif",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "keywords": [
        "claude",
        "stream",
        "viewer",
        "api",
        "json",
        "cli",
        "colorized",
        "pretty-print"
    ],
    "author": "Jerome Etienne <jerome.etienne@gmail.com>",
    "license": "MIT",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jeromeetienne/skillmd_collection.git",
        "directory": "packages/claude_stream_viewer"
    },
    "homepage": "https://github.com/jeromeetienne/skillmd_collection/tree/main/packages/claude_stream_viewer#readme",
    "bugs": {
        "url": "https://github.com/jeromeetienne/skillmd_collection/issues"
    },
    "dependencies": {
        "chalk": "^5.6.2",
        "commander": "^12.1.0"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "tsx": "^4.21.0",
        "typescript": "^5.3.3"
    }
}